# =============================================================
# EduIA — Variables de entorno requeridas
# =============================================================
# Copiar este archivo como:
#   - .streamlit/secrets.toml   (para la app Streamlit)
#   - o exportar como variables de entorno (para la API FastAPI)
#
# NUNCA subir el archivo real con claves al repositorio.
# =============================================================

# ─── Google Gemini AI ─────────────────────────────────────────
# Obtener gratis en: https://aistudio.google.com
# Requerida para: evaluación de código, generación de cursos, chat IA
GEMINI_API_KEY=tu_api_key_aqui

# ─── Modo de ejecución ────────────────────────────────────────
# Valores: true | false
DEBUG=false
DEVELOPMENT=false
TESTING=false

# ─── API FastAPI (opcional) ───────────────────────────────────
# Puerto donde corre la API (default: 8000)
# API_PORT=8000

# ─── Cómo configurar según el entorno ─────────────────────────
#
# Streamlit (app principal):
#   Crear .streamlit/secrets.toml con:
#     GEMINI_API_KEY = "tu_api_key_aqui"
#
# FastAPI (API REST):
#   Windows PowerShell:
#     $env:GEMINI_API_KEY="tu_api_key_aqui"
#   Linux / Mac:
#     export GEMINI_API_KEY=tu_api_key_aqui
#
# CI/CD (GitHub Actions):
#   Configurar en: Settings > Secrets > Actions > GEMINI_API_KEY
#   (Las pruebas unitarias NO requieren clave real)
